{
    "name": "pylot",
    "displayName": "Pylot - Python code runner",
    "description": "Executes lines of Python code with visualized smart selection.",
    "version": "1.12.1",
    "publisher": "bitagoras",
    "repository": "https://github.com/bitagoras/pylot",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:python",
        "onStartupFinished"
    ],
    "main": "./extension.js",
    "icon": "pylot.png",
    "contributes": {
        "configuration": {
            "title": "Pylot",
            "properties": {
                "pylot.replWorkingDirectory": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "${fileDirname}",
                        "${workspaceFolder}",
                        "${userHome}"
                    ],
                    "description": "Ordered list of candidate working directories for the Python session. Each entry is tried in order; the first one that resolves to an existing directory is used. Supports VS Code variables: ${fileDirname} (directory of the active file, skipped for unnamed files), ${workspaceFolder}, ${userHome}, and absolute paths. For unnamed (untitled) files, entries that cannot be resolved are skipped, so the Python session keeps its current working directory unchanged."
                },
                "pylot.matplotlibEventHandler": {
                    "type": "string",
                    "enum": [
                        "always",
                        "auto",
                        "never"
                    ],
                    "enumDescriptions": [
                        "Always load Matplotlib event handler.",
                        "Auto-detect 'matplotlib' keyword to load event handler before execution.",
                        "Never load Matplotlib event handler."
                    ],
                    "default": "auto",
                    "description": "Controls when the Matplotlib non-blocking event handler is injected into the Python session."
                },
                "pylot.executionMarkerStyle": {
                    "type": "string",
                    "enum": [
                        "off",
                        "border",
                        "gutter"
                    ],
                    "enumDescriptions": [
                        "Disable execution state markers.",
                        "Use left-border line markers.",
                        "Use gutter icon markers."
                    ],
                    "default": "gutter",
                    "description": "Configures the visual style of execution state markers."
                },
                "pylot.debug.python": {
                    "type": "boolean",
                    "default": false,
                    "description": "Pylot: Debug Mode Python. Enables detailed debug output in the Pylot output panel for the Python session and smart selection. (Requires Python restart for some features to take effect)"
                },
                "pylot.debug.mcpServer": {
                    "type": "boolean",
                    "default": false,
                    "description": "Pylot: Debug Mode MCP Server. Enables detailed debug output for the internal MCP server."
                },
                "pylot.mcpServer.enabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "Start an internal MCP server so external AI agents (e.g. Kilocode) can call Pylot tools directly via the SSE (Server-Sent Events) transport. This eliminates the need for an external Node.js bridge script. Requires a window reload to take effect."
                },
                "pylot.mcpServer.port": {
                    "type": "integer",
                    "default": 7822,
                    "minimum": 1024,
                    "maximum": 65535,
                    "description": "Localhost port for the Pylot MCP server. Clients should connect to the SSE endpoint: http://localhost:[port]/sse. Requires a window reload to take effect."
                },
                "pylot.enableInlayHints": {
                    "type": "boolean",
                    "default": true,
                    "description": "Pylot: Enable Live Variable Overlay. Shows variable values at the end of executed Python lines using Inlay Hints."
                },
                "pylot.enableForLoopLiveUpdates": {
                    "type": "boolean",
                    "default": true,
                    "description": "Pylot: Enable timer-based live updates for for-loops. Disabling this stops the progress bar and in-loop variable updates, but keeps normal post-execution inlay hints."
                },
                "pylot.enableWatchComments": {
                    "type": "boolean",
                    "default": true,
                    "description": "Pylot: Enable implicit live watches for lines ending with #?. Disabling this ignores #? markers entirely."
                },
                "pylot.maxInlayHintLength": {
                    "type": "integer",
                    "default": 50,
                    "minimum": 10,
                    "maximum": 500,
                    "description": "Pylot: Maximum length of Inlay Hints. Values longer than this will be truncated."
                },
                "pylot.inlayHintColor": {
                    "type": "string",
                    "default": "#5588ff77",
                    "description": "Pylot: Color for the Live Variable Overlay (CSS hex, e.g. #5588ff77)."
                },
                "pylot.showEditorTitleButtons": {
                    "type": "boolean",
                    "default": true,
                    "description": "Pylot: Show run buttons (▶  ▶|  ▶▶) in the top-right editor toolbar for Python files. Individual buttons can be hidden by right-clicking them."
                },
                "pylot.usePythonEnvironmentsExtension": {
                    "type": "boolean",
                    "default": false,
                    "description": "Pylot: Use the Python Environments extension to get the Python session. This ensures an activated environment (e.g. conda) with all environment variables."
                }
            }
        },
        "commands": [
            {
                "command": "pylot.executeSelectedPython",
                "title": "Pylot: Execute Selected Python",
                "icon": {
                    "light": "resources/icons/run-move-light.svg",
                    "dark": "resources/icons/run-move-dark.svg"
                }
            },
            {
                "command": "pylot.executeSelectedPythonNoMove",
                "title": "Pylot: Execute Selected Python (No Cursor Move)",
                "icon": {
                    "light": "resources/icons/run-light.svg",
                    "dark": "resources/icons/run-dark.svg"
                }
            },
            {
                "command": "pylot.runWholeFile",
                "title": "Pylot: Run Whole Python File",
                "icon": {
                    "light": "resources/icons/run-all-light.svg",
                    "dark": "resources/icons/run-all-dark.svg"
                }
            },
            {
                "command": "pylot.startPython",
                "title": "Pylot: Restart Python Session"
            },
            {
                "command": "pylot.clearOutput",
                "title": "Pylot: Clear Python Output"
            },
            {
                "command": "pylot.hideActiveLineMarkers",
                "title": "Pylot: Hide Active Line Markers"
            },
            {
                "command": "pylot.evaluateExpression",
                "title": "Pylot: Evaluate Python Expression"
            },
            {
                "command": "pylot.clearInlayHints",
                "title": "Pylot: Clear Inlay Hints"
            },
            {
                "command": "pylot.toggleInlayHints",
                "title": "Pylot: Toggle Inlay Hints"
            },
            {
                "command": "pylot.interruptExecution",
                "title": "Pylot: Interrupt Execution"
            },
            {
                "command": "pylot.openDataBrowser",
                "title": "Pylot: Open Data Browser"
            },
            {
                "command": "pylot.openObjectBrowser",
                "title": "Pylot: Open Object Browser"
            },
            {
                "command": "pylot.showGlobalVariables",
                "title": "Pylot: Show Global Variables"
            },
            {
                "command": "pylot.agent.appendAndExecute",
                "title": "Pylot Agent: Append and Execute Code"
            },
            {
                "command": "pylot.agent.executeRange",
                "title": "Pylot Agent: Execute Code in Range"
            },
            {
                "command": "pylot.agent.getExecutionStatus",
                "title": "Pylot Agent: Get Execution Status"
            },
            {
                "command": "pylot.agent.evaluateExpression",
                "title": "Pylot Agent: Evaluate Expression"
            },
            {
                "command": "pylot.agent.getOutput",
                "title": "Pylot Agent: Get execution Output"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "pylot.runWholeFile",
                    "when": "pylotActive && editorLangId == python && config.pylot.showEditorTitleButtons",
                    "group": "navigation@1"
                },
                {
                    "command": "pylot.executeSelectedPythonNoMove",
                    "when": "pylotActive && editorLangId == python && config.pylot.showEditorTitleButtons",
                    "group": "navigation@2"
                },
                {
                    "command": "pylot.executeSelectedPython",
                    "when": "pylotActive && editorLangId == python && config.pylot.showEditorTitleButtons",
                    "group": "navigation@3"
                }
            ],
            "commandPalette": [
                {
                    "command": "pylot.agent.appendAndExecute",
                    "when": "false"
                },
                {
                    "command": "pylot.agent.executeRange",
                    "when": "false"
                },
                {
                    "command": "pylot.agent.getExecutionStatus",
                    "when": "false"
                },
                {
                    "command": "pylot.agent.evaluateExpression",
                    "when": "false"
                },
                {
                    "command": "pylot.agent.getOutput",
                    "when": "false"
                }
            ]
        },
        "keybindings": [
            {
                "command": "pylot.clearOutput",
                "key": "ctrl+shift+c",
                "when": "pylotActive && editorTextFocus && editorLangId == python"
            },
            {
                "command": "pylot.executeSelectedPython",
                "key": "shift+enter",
                "when": "pylotActive && editorTextFocus && editorLangId == python && !isCompositeNotebook && !jupyter.ownsSelection && !notebookEditorFocused && !findInputFocussed && !replaceInputFocussed"
            },
            {
                "command": "pylot.evaluateExpression",
                "key": "shift+tab",
                "when": "pylotActive && editorTextFocus && editorLangId == python"
            },
            {
                "command": "pylot.executeSelectedPythonNoMove",
                "key": "shift+ctrl+enter",
                "when": "pylotActive && editorTextFocus && editorLangId == python && !isCompositeNotebook && !jupyter.ownsSelection && !notebookEditorFocused && !findInputFocussed && !replaceInputFocussed"
            },
            {
                "command": "pylot.runWholeFile",
                "key": "shift+ctrl+alt+enter",
                "when": "pylotActive && editorTextFocus && editorLangId == python && !isCompositeNotebook && !jupyter.ownsSelection && !notebookEditorFocused && !findInputFocussed && !replaceInputFocussed && !suggestWidgetVisible"
            },
            {
                "command": "pylot.interruptExecution",
                "key": "ctrl+alt+c",
                "when": "pylotActive && editorTextFocus && editorLangId == python"
            },
            {
                "command": "pylot.openDataBrowser",
                "key": "ctrl+shift+space",
                "when": "pylotActive && editorTextFocus && editorLangId == python"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "set NODE_OPTIONS=--no-deprecation && vsce package"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@types/node": "18.x",
        "typescript": "^5.3.3"
    },
    "extensionDependencies": [
        "ms-python.python"
    ]
}